# 複製此檔為 .env 並填入你的 API 金鑰
# cp .env.example .env

# ── Telegram Bot 推播（Phase 5-A）──────────────────────────────────
# 設定步驟：
#   1. Telegram 搜尋 @BotFather → /newbot → 取得 BOT_TOKEN
#   2. 對你的 Bot 發任意訊息
#   3. 瀏覽 https://api.telegram.org/bot<BOT_TOKEN>/getUpdates
#      找到 "chat" → "id" 的數字 → 填入 CHAT_ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── 其他 API（選用）────────────────────────────────────────────────
# NewsAPI（P2，可選）
NEWSAPI_KEY=your_newsapi_key_here

# SerpAPI（Google Trends 被限流時的備援，P2）
SERPAPI_KEY=your_serpapi_key_here
